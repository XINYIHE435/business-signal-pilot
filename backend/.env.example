# SignalPilot Backend 环境变量配置

# AI API Keys (至少配置一个)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEFAULT_LLM=claude

# 数据库配置
DATABASE_PATH=../data/signal.db

# API 配置
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# 日志配置
LOG_LEVEL=INFO
DEBUG=false
